---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Work — Harun Torlak" description="Projects from freelancing and university work.">
  <section class="section">
    <div class="container">
      <h1 class="reveal" style="margin:0 0 .6rem; font-size: clamp(2rem, 1.2rem + 2.4vw, 3rem); letter-spacing:-.03em;">
        Projects
      </h1>

      <div class="grid cols-3" style="margin-top:1rem;">
        <!-- Project 1: Kamen Hreša Website -->
        <article class="card reveal" data-delay="1">
          <h3 style="margin:0 0 .4rem;">Kamen Hreša Website</h3>
          <p style="margin:0; color: rgba(238,240,255,.72);">Jan 2026 – Present · Frontend</p>

          <ul class="list" style="margin:.7rem 0 0;">
            <li>Responsive, performance-optimized frontend with reusable components.</li>
            <li>SMTP email functionality for contact form submissions.</li>
            <li>Production deployment + basic SEO optimization.</li>
          </ul>

          <!-- was: .tag tags — now pills -->
          <div class="stack-pills" style="margin-top:.85rem;">
            <span class="pill"><span class="pill-dot"></span>React</span>
            <span class="pill"><span class="pill-dot"></span>Vite</span>
            <span class="pill"><span class="pill-dot"></span>SMTP</span>
            <span class="pill"><span class="pill-dot"></span>SEO</span>
          </div>
        </article>

        <!-- Project 2: University Event Manager -->
        <article class="card reveal" data-delay="2">
          <h3 style="margin:0 0 .4rem;">University Event Manager</h3>
          <p style="margin:0; color: rgba(238,240,255,.72);">Oct 2025 – Jan 2026 · Bachelor Thesis</p>

          <ul class="list" style="margin:.7rem 0 0;">
            <li>Event management with registration, roles, and admin dashboards.</li>
            <li>Google Sign‑In + Google Calendar API synchronization.</li>
            <li>Gemini AI-powered chatbot to assist users.</li>
          </ul>

          <!-- was: .tag tags — now pills -->
          <div class="stack-pills" style="margin-top:.85rem;">
            <span class="pill"><span class="pill-dot"></span>ASP.NET Core MVC</span>
            <span class="pill"><span class="pill-dot"></span>C#</span>
            <span class="pill"><span class="pill-dot"></span>Razor Pages</span>
            <span class="pill"><span class="pill-dot"></span>Entity Framework</span>
            <span class="pill"><span class="pill-dot"></span>SQL Server</span>
            <span class="pill"><span class="pill-dot"></span>Google Calendar API</span>
          </div>
        </article>

        <!-- Project 3: AtoB Mobile Application -->
        <article class="card reveal" data-delay="3">
          <h3 style="margin:0 0 .4rem;">AtoB Mobile Application</h3>
          <p style="margin:0; color: rgba(238,240,255,.72);">Mobile Development</p>

          <ul class="list" style="margin:.7rem 0 0;">
            <li>Ride‑hailing app concept: booking nearby drivers + real-time ride tracking.</li>
            <li>Firebase Authentication + Firestore for secure user and trip data.</li>
            <li>UI/UX consistency and performance optimizations for iOS/Android.</li>
          </ul>

          <!-- was: .tag tags — now pills -->
          <div class="stack-pills" style="margin-top:.85rem;">
            <span class="pill"><span class="pill-dot"></span>React Native</span>
            <span class="pill"><span class="pill-dot"></span>Firebase Auth</span>
            <span class="pill"><span class="pill-dot"></span>Firestore</span>
            <span class="pill"><span class="pill-dot"></span>Mobile UI/UX</span>
          </div>
        </article>

        <!-- Project 4: HCareMed -->
        <article class="card reveal" data-delay="1">
          <h3 style="margin:0 0 .4rem;">HCareMed</h3>
          <p style="margin:0; color: rgba(238,240,255,.72);">
            Freelance · WordPress (Bricks Builder)
          </p>

          <ul class="list" style="margin:.7rem 0 0;">
            <li>Live healthcare website built for real users (production-focused).</li>
            <li>Payment integration + login and user account flows.</li>
            <li>Structured user journey from services → account access → plan selection.</li>
          </ul>

          <!-- was: .tag tags — now pills -->
          <div class="stack-pills" style="margin-top:.85rem;">
            <span class="pill"><span class="pill-dot"></span>WordPress</span>
            <span class="pill"><span class="pill-dot"></span>Bricks Builder</span>
            <span class="pill"><span class="pill-dot"></span>Payments</span>
            <span class="pill"><span class="pill-dot"></span>Auth/Accounts</span>
          </div>
        </article>

        <!-- Project 5: Footwear E‑commerce SPA -->
        <article class="card reveal" data-delay="2">
          <h3 style="margin:0 0 .4rem;">Footwear E‑commerce SPA</h3>
          <p style="margin:0; color: rgba(238,240,255,.72);">
            Frontend · Single‑Page App
          </p>

          <ul class="list" style="margin:.7rem 0 0;">
            <li>Product listing + details, cart, wishlist, checkout flow.</li>
            <li>Modular page views with smooth navigation (no full reloads).</li>
            <li>Responsive UI and reusable front-end components.</li>
          </ul>

          <!-- was: .tag tags — now pills -->
          <div class="stack-pills" style="margin-top:.85rem;">
            <span class="pill"><span class="pill-dot"></span>HTML</span>
            <span class="pill"><span class="pill-dot"></span>CSS</span>
            <span class="pill"><span class="pill-dot"></span>Sass</span>
            <span class="pill"><span class="pill-dot"></span>Bootstrap</span>
            <span class="pill"><span class="pill-dot"></span>jQuery</span>
            <span class="pill"><span class="pill-dot"></span>SPApp</span>
          </div>
        </article>

        <!-- Project 6: Moco Museum Redesign -->
        <article class="card reveal" data-delay="3">
          <h3 style="margin:0 0 .4rem;">Moco Museum Redesign</h3>
          <p style="margin:0; color: rgba(238,240,255,.72);">
            Redesign · WordPress (Bricks Builder)
          </p>

          <ul class="list" style="margin:.7rem 0 0;">
            <li>Improved visual hierarchy and layout structure.</li>
            <li>Modernized presentation of cultural/exhibition content.</li>
            <li>Focus on UX and clean implementation in WordPress.</li>
          </ul>

          <!-- was: .tag tags — now pills -->
          <div class="stack-pills" style="margin-top:.85rem;">
            <span class="pill"><span class="pill-dot"></span>WordPress</span>
            <span class="pill"><span class="pill-dot"></span>Bricks Builder</span>
            <span class="pill"><span class="pill-dot"></span>UI/UX</span>
            <span class="pill"><span class="pill-dot"></span>Layout</span>
          </div>
        </article>

        <!-- Project 7: Booking.com Selenium Testing -->
        <article class="card reveal" data-delay="1">
          <h3 style="margin:0 0 .4rem;">Booking.com Selenium Testing</h3>
          <p style="margin:0; color: rgba(238,240,255,.72);">
            QA Automation · Selenium
          </p>

          <ul class="list" style="margin:.7rem 0 0;">
            <li>Automated browser flows to simulate and verify user journeys.</li>
            <li>Tested interaction logic and reliability across key scenarios.</li>
            <li>Hands-on QA workflow experience with dynamic web apps.</li>
          </ul>

          <!-- was: .tag tags — now pills -->
          <div class="stack-pills" style="margin-top:.85rem;">
            <span class="pill"><span class="pill-dot"></span>Selenium</span>
            <span class="pill"><span class="pill-dot"></span>Test Automation</span>
            <span class="pill"><span class="pill-dot"></span>QA</span>
          </div>
        </article>
      </div>

      <h2 class="reveal" style="margin-top:3rem;">Experience</h2>

      <div class="xp">
        <article class="card xp-item reveal" data-delay="1">
          <div class="xp-top">
            <div class="xp-title">
              <span class="xp-role">Co‑Founder & Developer</span>
              <span class="xp-at">·</span>
              <span class="xp-company">Projekat Studio</span>
            </div>
            <div class="xp-dates">Apr 2025 – Present</div>
          </div>

          <div class="xp-desc">
            Student‑oriented digital studio providing IT project assistance.
          </div>

          <div class="xp-pills">
            <span class="xp-pill">WordPress (Bricks)</span>
            <span class="xp-pill">Figma UI/UX</span>
            <span class="xp-pill">HTML/CSS</span>
            <span class="xp-pill">PHP</span>
          </div>
        </article>

        <article class="card xp-item reveal" data-delay="2">
          <div class="xp-top">
            <div class="xp-title">
              <span class="xp-role">Intern</span>
              <span class="xp-at">·</span>
              <span class="xp-company">SafeNet d.o.o., Sarajevo</span>
            </div>
            <div class="xp-dates">Nov 2024 – Jan 2025</div>
          </div>

          <div class="xp-desc">
            Worked on a .NET Framework project focused on C# and HTML development.
          </div>

          <div class="xp-pills">
            <span class="xp-pill">.NET Framework</span>
            <span class="xp-pill">C#</span>
            <span class="xp-pill">HTML</span>
          </div>
        </article>
      </div>
    </div>
  </section>
</BaseLayout>