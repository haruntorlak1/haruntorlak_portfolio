---
import BaseLayout from "../layouts/BaseLayout.astro";
import Hero from "../components/Hero.astro";
---

<BaseLayout title="Harun Torlak — Portfolio" description="Freelance and university projects portfolio.">
  <Hero />

  <section class="section">
    <div class="container">
      <h2 class="reveal">Snapshot</h2>

      <!-- was: grid cols-3 snapshot-grid -->
      <div class="snapshot-stack" style="margin-top:1.35rem;">
        <article class="card reveal" data-delay="1">
          <h3 style="margin:0 0 .5rem;">Experience</h3>
          <ul class="list" style="margin:0;">
            <li><strong>Projekat Studio</strong> — Co‑Founder & Developer (Apr 2025 – Present)</li>
            <li><strong>SafeNet d.o.o.</strong> — Software Engineer Intern (Nov 2024 – Jan 2025)</li>
          </ul>
        </article>

        <article class="card reveal" data-delay="2">
          <h3 style="margin:0 0 .5rem;">Education</h3>
          <ul class="list" style="margin:0;">
            <li><strong>International Burch University</strong> — BSc Information Technology</li>
            <li><strong>Treća gimnazija</strong> — IT diploma</li>
          </ul>
        </article>

        <article class="card reveal" data-delay="3">
          <h3 style="margin:0 0 .4rem;">Core stack</h3>

          <div class="stack-pills" aria-label="Core stack">
            <span class="pill"><span class="pill-dot"></span>C#</span>
            <span class="pill"><span class="pill-dot"></span>ASP.NET Core</span>
            <span class="pill"><span class="pill-dot"></span>Entity Framework</span>
            <span class="pill"><span class="pill-dot"></span>SQL Server</span>

            <span class="pill"><span class="pill-dot"></span>React</span>
            <span class="pill"><span class="pill-dot"></span>Vite</span>
            <span class="pill"><span class="pill-dot"></span>React Native</span>

            <span class="pill"><span class="pill-dot"></span>Firebase</span>
            <span class="pill"><span class="pill-dot"></span>WordPress (Bricks)</span>
            <span class="pill"><span class="pill-dot"></span>Figma</span>
          </div>
        </article>
      </div>

      <div class="btn-row reveal" data-delay="2" style="margin-top:1.2rem;">
        <a class="btn primary" href="/work">Projects</a>
        <a class="btn" href="/about#contact">Contact</a>
      </div>
    </div>
  </section>

  <style>
    .snapshot-stack{
      display: grid;
      grid-template-columns: 1fr;
      gap: 1.15rem;
      align-items: start;
      max-width: 820px; /* keeps it clean, not too wide */
    }
  </style>
</BaseLayout>